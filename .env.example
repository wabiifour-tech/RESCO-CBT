# ============================================
# RESCO-CBT Environment Variables Template
# Copy this file to .env and fill in real values
# ============================================

# --- Database ---
# Local dev (SQLite):  DATABASE_URL=file:/home/z/my-project/db/custom.db
# Railway (PostgreSQL): Injected automatically by Railway — do NOT set manually
DATABASE_URL=

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Authentication ---
# CRITICAL: Must be set! Generate a strong random string for production.
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# --- CORS ---
# Your frontend URL (used in CORS whitelist)
CLIENT_URL=http://localhost:5173

# --- Principal Account (auto-seeded on first startup) ---
PRINCIPAL_EMAIL=principal@resco
PRINCIPAL_PASSWORD=affordables
