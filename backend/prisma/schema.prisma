generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("STUDENT")
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student?
  teacher Teacher?

  @@map("users")
}

model Student {
  id          String @id @default(uuid())
  admissionNo String @unique @map("admission_no")
  firstName   String @map("first_name")
  lastName    String @map("last_name")
  className   String @default("JSS1") @map("class_name")

  user    User     @relation(fields: [id], references: [id], onDelete: Cascade)
  results Result[]

  @@map("students")
}

model Teacher {
  id        String  @id @default(uuid())
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  username  String  @unique
  status    String  @default("ACTIVE")
  subjects  String  @default("[]")

  user   User   @relation(fields: [id], references: [id], onDelete: Cascade)
  exams  Exam[]

  @@map("teachers")
}

model Exam {
  id               String   @id @default(uuid())
  title            String
  description      String?
  type             String   @default("TEST")
  status           String   @default("DRAFT")
  duration         Int
  totalMarks       Int      @default(100)
  passMark         Int      @default(50)
  startDate        String   @default("")
  endDate          String   @default("")
  resultVisibility String   @default("MANUAL") @map("result_visibility")
  shuffleQuestions Int      @default(0) @map("shuffle_questions")
  shuffleOptions   Int      @default(0) @map("shuffle_options")
  className        String   @default("JSS1") @map("class_name")
  subject          String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  teacherId String  @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  questions ExamQuestion[]
  results   Result[]

  @@map("exams")
}

model ExamQuestion {
  id       String @id @default(uuid())
  examId   String @map("exam_id")
  question String
  optionA  String @map("option_a")
  optionB  String @map("option_b")
  optionC  String @map("option_c")
  optionD  String @map("option_d")
  answer   String
  marks    Int    @default(1)

  exam          Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  resultAnswers ResultAnswer[]

  @@map("exam_questions")
}

model Result {
  id            String         @id @default(uuid())
  examId        String         @map("exam_id")
  studentId     String         @map("student_id")
  score         Int
  totalMarks    Int            @default(100) @map("total_marks")
  percentage    Float          @default(0)
  submittedAt   DateTime       @default(now()) @map("submitted_at")
  timeSpent     Int            @default(0) @map("time_spent")
  examStartTime DateTime       @default(now()) @map("exam_start_time")
  examEndTime   DateTime       @default(now()) @map("exam_end_time")

  exam     Exam          @relation(fields: [examId], references: [id])
  student  Student       @relation(fields: [studentId], references: [id])
  answers  ResultAnswer[]

  @@unique([examId, studentId])
  @@map("results")
}

model ResultAnswer {
  id         String @id @default(uuid())
  resultId   String @map("result_id")
  questionId String @map("question_id")
  selected   String?
  correct    Int    @default(0)

  result  Result       @relation(fields: [resultId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id])

  @@map("result_answers")
}

model Settings {
  id    String @id @default("general")
  key   String @unique
  value String

  @@map("settings")
}
