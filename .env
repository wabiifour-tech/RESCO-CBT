# ============================================
# RESCO-CBT Environment Variables
# ============================================

# --- Database ---
# Local development: SQLite
# Railway production: PostgreSQL (injected automatically)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Authentication ---
# CRITICAL: JWT secret for signing/verifying tokens
# Generate a secure random string for production!
JWT_SECRET=resco_cbt_jwt_secret_2024_secure_key_change_in_production

# --- CORS ---
# Frontend URL for CORS whitelist
CLIENT_URL=http://localhost:5173

# --- Principal Account (auto-seeded on startup) ---
PRINCIPAL_EMAIL=principal@resco
PRINCIPAL_PASSWORD=affordables

# --- Frontend API ---
# Set in frontend/.env as VITE_API_URL
# Default: https://resco-cbt-production.up.railway.app/api
